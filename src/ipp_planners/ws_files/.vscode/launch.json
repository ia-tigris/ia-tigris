        {
            "name": "main.launch - Search & Track",
            "type": "ros",
            "request": "launch",
            "target": "${workspaceFolder}/src/ipp_planners/launch/main.launch",
            "preLaunchTask": "catkin: build",
            "arguments": ["search:=true", "track:=true", "rviz:=true", "vis_while_planning:=true", "planner:=tigris", "loglevel:=debug", "sim:=simple"]
        },
        {
            "name": "main.launch - Search & Track no sim",
            "type": "ros",
            "request": "launch",
            "target": "${workspaceFolder}/src/ipp_planners/launch/main.launch",
            "preLaunchTask": "catkin: build",
            "arguments": ["search:=true", "track:=true", "rviz:=true", "vis_while_planning:=true", "planner:=tigris", "loglevel:=debug", "sim:=false"]
        },
        {
            "name": "main.launch - Search Only",
