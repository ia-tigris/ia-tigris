Panels:
  - Class: rviz/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /CameraPub1
        - /Axes1
        - /Axes2
      Splitter Ratio: 0.5018450021743774
    Tree Height: 400
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: Image
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 200
      Class: rviz/Grid
      Color: 157; 204; 238
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 5000
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /simulator/markers/agent_pose
      Name: "Agent: Mesh"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /simulator/markers/camera_projection
      Name: "Agent: Camera Projection"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /simulator/markers/agent_trajectory
      Name: "Agent: Path History"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/targets
      Name: "Targets: Meshes"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /search_belief
      Name: "Belief: Search Grid"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /particle_filters_visualizer
      Name: "Belief: Particle Filters"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/planner_boundary
      Name: "Plan: Bounds"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /global_path/sampled_points
      Name: "Plan: Sampled Points"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /global_path/info_gain_text
      Name: "Plan: Info Gain Text"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /global_path/mcts_avg_value_text
      Name: "Plan: MCTS Average Value"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /ipp_planners_node/rollout
      Name: "Plan: MCTS Rollouts"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/keep_out_zones
      Name: "Plan: Keep Out Zones"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/tree
      Name: "Plan: Tree"
      Namespaces:
        {}
      Queue Size: 0
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/final_path_observations
      Name: "Plan: Path Observations"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /global_path/viz
      Name: "Output: Planned Path (published /global_path)"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/final_path
      Name: "Output: Total Path (from replans)"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Background Color: 0; 0; 0
      Camera Info Topic: /camera1/camera_info
      Class: rviz_camera_stream/CameraPub
      Display namespace: ""
      Enabled: true
      Frame Rate: 1
      Image Encoding: rgb8
      Image Topic: /rviz1/camera1/image
      Name: CameraPub
      Near Clip Distance: 7000
      Queue Size: 2
      Value: true
      Visibility:
        "Agent: Camera Projection": true
        "Agent: Mesh": true
        "Agent: Path History": true
        Axes: true
        "Belief: Particle Filters": true
        "Belief: Search Grid": true
        Grid: true
        Image: true
        "Output: Planned Path (published /global_path)": true
        "Output: Total Path (from replans)": true
        "Plan: Bounds": true
        "Plan: Info Gain Text": true
        "Plan: Keep Out Zones": true
        "Plan: MCTS Average Value": true
        "Plan: MCTS Rollouts": true
        "Plan: Path Observations": true
        "Plan: Sampled Points": true
        "Plan: Tree": true
        "Targets: Meshes": true
        Value: true
    - Class: rviz/Image
      Enabled: true
      Image Topic: /rviz1/camera1/image
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Image
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: true
    - Class: rviz/Axes
      Enabled: true
      Length: 100
      Name: Axes
      Radius: 10
      Reference Frame: camera1
      Value: true
    - Class: rviz/Axes
      Enabled: true
      Length: 100
      Name: Axes
      Radius: 10
      Reference Frame: local_enu
      Value: true
  Enabled: true
  Global Options:
    Background Color: 255; 255; 255
    Default Light: true
    Fixed Frame: local_enu
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 5288.91943359375
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 725.1209106445312
        Y: 2412.505126953125
        Z: -3001.9375
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.8997969627380371
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz)
      Yaw: 4.493187427520752
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 870
  Hide Left Dock: false
  Hide Right Dock: true
  Image:
    collapsed: false
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: true
  Width: 1440
  X: 337
  Y: 141
