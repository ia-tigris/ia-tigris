Panels:
  - Class: rviz/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded: ~
      Splitter Ratio: 0.9882352948188782
    Tree Height: 907
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: ""
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 200
      Class: rviz/Grid
      Color: 157; 204; 238
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 5000
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /simulator/markers/agent_pose
      Name: "Agent: Mesh"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /simulator/markers/camera_projection
      Name: "Agent: Camera Projection"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /simulator/markers/agent_trajectory
      Name: "Agent: Path History"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/targets
      Name: "Targets: Meshes"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /search_belief
      Name: "Belief: Search Grid"
      Namespaces:
        nodes: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /particle_filters_visualizer
      Name: "Belief: Particle Filters"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/planner_boundary
      Name: "Plan: Bounds"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /global_path/sampled_points
      Name: "Plan: Sampled Points"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /global_path/info_gain_text
      Name: "Plan: Info Gain Text"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /global_path/mcts_avg_value_text
      Name: "Plan: MCTS Average Value"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /ipp_planners_node/rollout
      Name: "Plan: MCTS Rollouts"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/tree
      Name: "Plan: Tree"
      Namespaces:
        {}
      Queue Size: 0
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/final_path_observations
      Name: "Plan: Path Observations"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /global_path/viz
      Name: "Output: Planned Path (published /global_path)"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/final_path
      Name: "Output: Total Path (from replans)"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/agent_mesh
      Name: UAV Mesh
      Namespaces:
        agent_mesh: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/agent_trajectory
      Name: UAV History
      Namespaces:
        agent_trajectory: true
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /realtime_search/markers/agent_pose
      Name: Map Update Projection
      Namespaces:
        nodes: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /global_path/waypoint_nums
      Name: Waypoint Numbers
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /global_path/waypoints
      Name: Waypoints
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: jsk_rviz_plugin/PieChart
      Enabled: true
      Name: Budget
      Topic: /remaining_budget
      Value: true
      auto color change: false
      background color: 0; 0; 0
      backround alpha: 0
      clockwise rotate direction: false
      foreground alpha: 0.699999988079071
      foreground alpha 2: 0.4000000059604645
      foreground color: 25; 255; 240
      left: 128
      max color: 255; 0; 0
      max color change threthold: 0
      max value: 15000
      med color: 255; 0; 0
      med color change threthold: 0
      min value: 0
      show caption: true
      size: 128
      text size: 14
      top: 128
  Enabled: true
  Global Options:
    Background Color: 255; 255; 255
    Default Light: true
    Fixed Frame: local_enu
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 11091.2197265625
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Field of View: 0.7853981852531433
      Focal Point:
        X: 2495.810302734375
        Y: 3700.27197265625
        Z: -3725.181640625
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 1.5697963237762451
      Target Frame: <Fixed Frame>
      Yaw: 0
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 1136
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: true
  Width: 1852
  X: 68
  Y: 27
