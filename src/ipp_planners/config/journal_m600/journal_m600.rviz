Panels:
  - Class: rviz/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - "/Agent: Path Histories1/Namespaces1"
        - "/Belief: Particle Filters1/Namespaces1"
        - /Debug Simulated Perception1/Shape1
        - /Debug Simulated Perception1/Covariance1
        - /Debug Simulated Perception1/Covariance1/Position1
        - /Debug Simulated Perception1/Covariance1/Orientation1
        - /Budget1
        - /Odometry1/Shape1
      Splitter Ratio: 0.6000000238418579
    Tree Height: 533
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: ""
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 200
      Class: rviz/Grid
      Color: 157; 204; 238
      Enabled: false
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 5000
      Reference Frame: <Fixed Frame>
      Value: false
    - Class: rviz/TF
      Enabled: false
      Filter (blacklist): ""
      Filter (whitelist): ""
      Frame Timeout: 15
      Frames:
        All Enabled: false
      Marker Alpha: 1
      Marker Scale: 100
      Name: TF
      Show Arrows: false
      Show Axes: true
      Show Names: true
      Tree:
        {}
      Update Interval: 0
      Value: false
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/agent_mesh
      Name: "Agent: Meshes"
      Namespaces:
        agent_mesh: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/camera_projection
      Name: "Agent: Camera Projections"
      Namespaces:
        projection_marker: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /simulator/markers/camera_projection_points
      Name: "Agent: Camera Projection Points"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /simulator/markers/agent_trajectory
      Name: "Agent: Path Histories"
      Namespaces:
        {}
      Queue Size: 10000
      Value: false
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /simulator/markers/targets
      Name: "Targets: Meshes"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /uav1/search_belief
      Name: "Belief: Search Grid"
      Namespaces:
        nodes: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /uav1/particle_filters_visualizer
      Name: "Belief: Particle Filters"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /global_path/planner_boundary
      Name: "Plan: Bounds"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /uav1/global_path/sampled_points
      Name: "Plan: Sampled Points"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /uav1/global_path/info_gain_text
      Name: "Plan: Info Gain Text"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /uav1/global_path/mcts_avg_value_text
      Name: "Plan: MCTS Average Value"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /uav1/ipp_planners_node/rollout
      Name: "Plan: MCTS Rollouts"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /uav1/global_path/keep_out_zones
      Name: "Plan: Keep Out Zones"
      Namespaces:
        {}
      Queue Size: 100
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /uav1/global_path/tree
      Name: "Plan: Tree"
      Namespaces:
        nodes: true
      Queue Size: 0
      Value: true
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /uav1/global_path/final_path_observations
      Name: "Plan: Path Observations"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /uav1/global_path/viz
      Name: "Output: Planned Path (published /global_path)"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /uav1/global_path/final_path
      Name: "Output: Total Path (from replans)"
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /uav1/global_path/waypoints
      Name: Waypoints
      Namespaces:
        waypoint_vis: true
      Queue Size: 100
      Value: true
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /uav1/global_path/waypoint_nums
      Name: WaypointNum
      Namespaces:
        waypoint_num: true
      Queue Size: 100
      Value: true
    - Angle Tolerance: 0.10000000149011612
      Class: rviz/Odometry
      Covariance:
        Orientation:
          Alpha: 0.5
          Color: 255; 255; 127
          Color Style: Unique
          Frame: Local
          Offset: 1
          Scale: 10
          Value: true
        Position:
          Alpha: 0.30000001192092896
          Color: 204; 51; 204
          Scale: 10
          Value: true
        Value: true
      Enabled: false
      Keep: 1
      Name: Debug Simulated Perception
      Position Tolerance: 0.10000000149011612
      Queue Size: 10
      Shape:
        Alpha: 1
        Axes Length: 1
        Axes Radius: 0.10000000149011612
        Color: 255; 25; 0
        Head Length: 20
        Head Radius: 50
        Shaft Length: 50
        Shaft Radius: 25
        Value: Arrow
      Topic: /uav1/simulated_perception_node/observation_with_cov
      Unreliable: false
      Value: false
    - Class: jsk_rviz_plugin/PieChart
      Enabled: true
      Name: Budget
      Topic: /uav1/remaining_budget
      Value: true
      auto color change: true
      background color: 32; 74; 135
      backround alpha: 0
      clockwise rotate direction: false
      foreground alpha: 0.8999999761581421
      foreground alpha 2: 0.5
      foreground color: 239; 41; 41
      left: 50
      max color: 78; 154; 6
      max color change threthold: 0
      max value: 600
      med color: 173; 127; 168
      med color change threthold: 0
      min value: 0
      show caption: true
      size: 128
      text size: 15
      top: 50
    - Class: rviz/Image
      Enabled: false
      Image Topic: /uav1/seek_camera/displayImage
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Image
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
    - Class: rviz/Image
      Enabled: false
      Image Topic: /uav1/seek_camera/displayImage
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Seek Thermal (Downward)
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
    - Class: rviz/Image
      Enabled: false
      Image Topic: /uav1/sort/image_out
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Thermal Detections
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
    - Class: rviz/Image
      Enabled: false
      Image Topic: /uav1/thermal/image_rect
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: FLIR Thermal (Forward-Down)
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
    - Angle Tolerance: 0.10000000149011612
      Class: rviz/Odometry
      Covariance:
        Orientation:
          Alpha: 0.5
          Color: 255; 255; 127
          Color Style: Unique
          Frame: Local
          Offset: 1
          Scale: 1
          Value: true
        Position:
          Alpha: 0.30000001192092896
          Color: 204; 51; 204
          Scale: 1
          Value: true
        Value: true
      Enabled: true
      Keep: 99999999
      Name: Odometry
      Position Tolerance: 0.10000000149011612
      Queue Size: 10
      Shape:
        Alpha: 1
        Axes Length: 1
        Axes Radius: 0.10000000149011612
        Color: 255; 255; 0
        Head Length: 0
        Head Radius: 0
        Shaft Length: 1.5
        Shaft Radius: 2
        Value: Arrow
      Topic: /uav1/odometry
      Unreliable: false
      Value: true
    - Class: rviz/Image
      Enabled: false
      Image Topic: /uav1/object_detection/annotated_image
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Detections
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: false
    - Class: rviz/Marker
      Enabled: false
      Marker Topic: /uav1/realtime_search/markers/agent_pose
      Name: Camera Projection from Mapper
      Namespaces:
        {}
      Queue Size: 100
      Value: false
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /uav1/global_path/final_path
      Name: Final Path
      Namespaces:
        nodes: true
      Queue Size: 100
      Value: true
  Enabled: true
  Global Options:
    Background Color: 255; 255; 255
    Default Light: true
    Fixed Frame: world
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 946.9292602539062
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Field of View: 0.7853981852531433
      Focal Point:
        X: 37.514129638671875
        Y: -56.109405517578125
        Z: -36.11760711669922
      Focal Shape Fixed Size: false
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 1.5697963237762451
      Target Frame: <Fixed Frame>
      Yaw: 3.760404109954834
    Saved: ~
